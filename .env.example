# Runtime profile. Production fails fast if security-critical values below are unsafe.
ENVIRONMENT=development

# Development client key. It is bundled into Expo and is NOT a production secret.
BFF_API_KEY=replace-with-at-least-32-random-characters
BFF_API_KEY_FILE=
RATE_LIMIT_HASH_KEY=replace-with-a-separate-32-character-server-secret
RATE_LIMIT_HASH_KEY_FILE=

# Docker Compose requires a separate high-entropy Redis password. Redis is not
# published on the host in the hardened stack.
# Docker accepts 32–512 URL-safe characters only: A-Z, a-z, 0-9, _ and -.
REDIS_PASSWORD=replace_with_a_different_random_password_2026
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD_FILE=
REDIS_USE_TLS=false
# Container memory defaults; raise them only after measuring the real feed.
BFF_MEMORY_LIMIT=3g
REDIS_MEMORY_LIMIT=1536m
REDIS_MAXMEMORY=1gb

SERVER_HOST=127.0.0.1
SERVER_PORT=8000
# Only proxies in this exact IP/CIDR allow-list may supply X-Forwarded-*.
FORWARDED_ALLOW_IPS=127.0.0.1
TRUSTED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=
DOCS_ENABLED=true
LOG_LEVEL=info

RATE_LIMIT_RPM=60
RATE_LIMIT_WS_MPM=120
MAX_WS_CONNECTIONS=200
MAX_WS_CONNECTIONS_PER_IP=20
MAX_WS_TOPICS_PER_CLIENT=20
MAX_WS_MESSAGE_BYTES=4096
MAX_REQUEST_BODY_BYTES=32768
REQUEST_BODY_TIMEOUT_SECONDS=15

TELEMETRY_ENABLED=true
TELEMETRY_RETENTION_DAYS=3
TELEMETRY_MAX_EVENTS_PER_DAY=5000
TELEMETRY_MAX_ERRORS_PER_DAY=500
TELEMETRY_QUEUE_SIZE=2048

TOMTOM_API_KEY=
TOMTOM_API_KEY_FILE=
TRAFFIC_CACHE_TTL_SECONDS=900
TRAFFIC_GLOBAL_REQUESTS_PER_MINUTE=120
# Keeps TomTom Traffic API use below its 2,500 free daily non-tile requests.
TRAFFIC_GLOBAL_REQUESTS_PER_DAY=2300
TRAFFIC_PROVIDER_CIRCUIT_SECONDS=60

# Esri World Imagery is fetched server-side only; never add this key to Expo.
# Set the direct value for local LaunchAgent development, or use the *_FILE
# form with a Docker/Kubernetes secret in production.
ARCGIS_API_KEY=
ARCGIS_API_KEY_FILE=
SATELLITE_TILES_ENABLED=true
# Esri publishes its imagery cache policy as 24 hours; this value must not
# exceed it.  The bounded in-memory cache protects the monthly tile budget.
SATELLITE_TILE_CACHE_TTL_SECONDS=86400
SATELLITE_TILE_CACHE_ENTRIES=512
# Global cold-tile budget. Cache hits do not count. 50,000/day caps a
# 31-day month at 1.55M, below Esri's 2M free monthly basemap-tile allowance.
# The minute cap permits one normal cold map load without hitting the guard.
SATELLITE_GLOBAL_REQUESTS_PER_MINUTE=600
SATELLITE_GLOBAL_REQUESTS_PER_DAY=50000
# Stop new imagery fetches temporarily if Esri responds with a provider 429.
SATELLITE_PROVIDER_CIRCUIT_SECONDS=3600

# Keep provider URLs on the official HTTPS allow-list.
ATM_RT_TRIP_UPDATES_URL=https://t-mobilitat.atm.cat/opendata/trip_updates/user/token/open
ATM_RT_ALERTS_URL=https://t-mobilitat.atm.cat/opendata/alerts/user/token/open
ATM_RT_VEHICLE_POSITIONS_URL=https://t-mobilitat.atm.cat/opendata/vehicle_positions/user/token/open
ATM_RT_FRESHNESS_SECONDS=90
ATM_GTFS_URL=https://t-mobilitat.atm.cat/opendata/static/download/
OUTBOUND_ALLOWED_HOSTS=t-mobilitat.atm.cat,t-mobilitat.cat,api.tomtom.com,ibasemaps-api.arcgis.com
