# ==============================================================================
# Route-TMB BFF — Environment Configuration
# ==============================================================================

# --- Security & Authentication ---
# Machine-to-machine API key for tablet fleet authentication.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
BFF_API_KEY=dev-insecure-key-change-in-production

# --- Rate Limiting ---
RATE_LIMIT_RPM=60
RATE_LIMIT_WS_MPM=120

# --- WebSocket ---
MAX_WS_CONNECTIONS=200

# --- CORS ---
# Comma-separated allowed origins. Empty = same-origin only.
CORS_ALLOWED_ORIGINS=

# --- ATM T-mobilitat Real-Time (GTFS-RT) ---
ATM_RT_TRIP_UPDATES_URL=https://t-mobilitat.atm.cat/opendata/trip_updates/user/token/open
ATM_RT_ALERTS_URL=https://t-mobilitat.atm.cat/opendata/alerts/user/token/open
ATM_RT_VEHICLE_POSITIONS_URL=https://t-mobilitat.atm.cat/opendata/vehicle_positions/user/token/open
ATM_RT_POLL_INTERVAL_SECONDS=30

# --- ATM T-mobilitat Static GTFS ---
ATM_GTFS_URL=https://t-mobilitat.atm.cat/opendata/static/download/
ATM_GTFS_REFRESH_HOURS=24

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
