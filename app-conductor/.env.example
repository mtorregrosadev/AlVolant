# Expo inlines EXPO_PUBLIC_* values into the app bundle. This local-only value
# matches the root .env.example. Production must use a proper client-authentication flow.
EXPO_PUBLIC_BFF_API_KEY=alvolant-example-local-dev-api-key-2026-not-for-production

# Optional. When omitted, the app discovers the Metro host and uses port 8000.
# Use HTTPS/WSS outside local development.
EXPO_PUBLIC_BFF_URL=http://localhost:8000

# Optional map gateway override. `run-local.sh` injects its loopback-only
# gateway for an iPhone Simulator. When omitted from a device build, AlVolant
# uses the configured HTTPS BFF origin for the companion map assets.
# EXPO_PUBLIC_MAP_ORIGIN=https://maps.example.com

# Only for the loopback-only iPhone Simulator runner. It permits HTTP solely
# to localhost/127.0.0.1/::1; every other Release BFF origin still needs HTTPS.
EXPO_PUBLIC_ALLOW_INSECURE_LOOPBACK=1
