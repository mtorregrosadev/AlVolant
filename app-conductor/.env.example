# Expo inlines EXPO_PUBLIC_* values into the app bundle. Use a development-only
# BFF key here; production must use a proper client-authentication flow.
EXPO_PUBLIC_BFF_API_KEY=replace-with-a-development-key

# Optional. When omitted, the app discovers the Metro host and uses port 8000.
# Use HTTPS/WSS outside local development.
EXPO_PUBLIC_BFF_URL=http://localhost:8000
